---
layout: layouts/base.njk
showBackLink: true
---
{%- set createdAt = created or page.date %}
{%- set updatedAt = updated or createdAt %}
{%- set createdIso = createdAt | isoDate %}
{%- set updatedIso = updatedAt | isoDate %}
<div class="note-meta">
	<div class="note-meta__dates">
		<span class="note-meta__date-item">
			Created
			<time class="note-meta__date" datetime="{{ createdIso }}">{{ createdAt | dateFormat }}</time>
		</span>
		{%- if updatedIso != createdIso %}
		<span class="note-meta__date-item">
			Updated
			<time class="note-meta__date" datetime="{{ updatedIso }}">{{ updatedAt | dateFormat }}</time>
		</span>
		{%- endif %}
	</div>
	{%- if categories %}
	{%- for cat in categories %}
	<a href="/notes/category/{{ cat | slugify }}/" class="note-meta__category">#{{ cat }}</a>
	{%- endfor %}
	{%- endif %}
</div>

{{ content | safe }}

{%- set noteIndex = -1 %}
{%- for note in collections.notes %}
	{%- if note.url === page.url %}
		{%- set noteIndex = loop.index0 %}
	{%- endif %}
{%- endfor %}

{%- if noteIndex >= 0 %}
{%- set prevNote = collections.notes[noteIndex - 1] if noteIndex > 0 %}
{%- set nextNote = collections.notes[noteIndex + 1] if noteIndex < collections.notes.length - 1 %}

{%- if prevNote or nextNote %}
<nav class="note-nav" aria-label="Note navigation">
	{%- if prevNote %}
	<a href="{{ prevNote.url }}" class="note-nav__link note-nav__link--prev">
		<span class="note-nav__label">Previous</span>
		<span class="note-nav__title">{{ prevNote.data.title }}</span>
	</a>
	{%- endif %}
	{%- if nextNote %}
	<a href="{{ nextNote.url }}" class="note-nav__link note-nav__link--next">
		<span class="note-nav__label">Next</span>
		<span class="note-nav__title">{{ nextNote.data.title }}</span>
	</a>
	{%- endif %}
</nav>
{%- endif %}
{%- endif %}
